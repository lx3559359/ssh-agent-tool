# ============================================================
# WinkTerm Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================
#
# WinkTerm uses the OpenAI-compatible protocol.
# You can use ANY provider that supports it:
# - Anthropic (via API proxy)
# - OpenAI
# - Ollama (local)
# - OpenRouter
# - Groq
# - vLLM
# - etc.
#
# Quick start (Anthropic):
#   ANTHROPIC_API_KEY=sk-ant-...
#   (The backend auto-detects Anthropic and sets the correct base URL)
#
# Quick start (OpenAI):
#   OPENAI_API_KEY=sk-...
#
# Quick start (local Ollama):
#   OPENAI_BASE_URL=http://localhost:11434/v1
#   MODEL_NAME=llama3

# ------ LLM API ------
# Required: Use ONE of these based on your provider:

# Option A: Anthropic (recommended, best results)
ANTHROPIC_API_KEY=

# Option B: OpenAI
OPENAI_API_KEY=

# Option C: Custom OpenAI-compatible endpoint (Ollama, Groq, OpenRouter, etc.)
# OPENAI_BASE_URL=

# Model name (default depends on provider)
# For Anthropic: claude-sonnet-4-20250514, claude-3-5-sonnet-latest, claude-opus-4-6
# For OpenAI: gpt-4o, gpt-4o-mini
# For Ollama: llama3, qwen2, etc.
MODEL_NAME=

# ------ External Services (optional) ------
PROMETHEUS_URL=http://localhost:9090
LOKI_URL=http://localhost:3100

# ------ Backend Server ------
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ------ Agent ------
AGENT_RECURSION_LIMIT=100

# 外部 agent HTTP 接口的鉴权 token。
# 设置后 /api/agent/* 端点启用，外部 agent 请求需带 Authorization: Bearer <token>。
# 留空则该接口关闭（返回 503）。
AGENT_API_TOKEN=

# ------ Frontend (usually no change needed for local dev) ------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/terminal
