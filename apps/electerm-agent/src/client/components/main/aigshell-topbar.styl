.aigshell-topbar
  position absolute
  left 0
  right 0
  top 0
  height 44px
  z-index 400
  display flex
  align-items center
  justify-content space-between
  padding 0 14px
  background var(--main-light)
  border-bottom 1px solid var(--main-darker)
  color var(--text)
  -webkit-app-region drag

.aigshell-topbar-brand
  display flex
  align-items center
  gap 10px
  min-width 0
  height 100%
  font-size 13px
  img
    width 24px
    height 24px
    border-radius 5px
    flex none

.aigshell-topbar-name
  font-weight 650
  color var(--text-light)
  white-space nowrap

.aigshell-topbar-version
  height 20px
  line-height 20px
  padding 0 7px
  border-radius 999px
  color var(--primary)
  background var(--main)
  font-size 12px
  font-weight 600
  white-space nowrap
  flex none

.aigshell-topbar-separator
  width 1px
  height 18px
  background var(--main-darker)
  flex none

.aigshell-topbar-current
  max-width 260px
  overflow hidden
  text-overflow ellipsis
  white-space nowrap
  color var(--text)
  font-weight 500

.aigshell-topbar-dot
  width 7px
  height 7px
  border-radius 50%
  background var(--text-disabled)
  flex none
  &.online
    background var(--success)

.aigshell-topbar-actions
  display flex
  align-items center
  gap 6px
  min-width 0
  height 100%
  padding-right 138px
  -webkit-app-region no-drag

.aigshell-topbar-action-wrap
  display inline-flex
  align-items center

.aigshell-topbar-action
  height 30px
  padding 0 10px
  color var(--text)
  border-radius 6px
  font-size 13px
  font-weight 500
  &:hover
    color var(--primary) !important
    background var(--main) !important

.aigshell-topbar-action-primary
  border 1px solid var(--primary)
  color var(--primary)
  background var(--main)
  box-shadow 0 0 0 1px rgba(0, 0, 0, .02)
  &:hover
    border-color var(--primary) !important
    color var(--primary) !important
    background var(--main-light) !important

.aigshell-topbar
  .window-controls
    top 0
    right 0
    height 44px
    background transparent
    border-radius 0
    display flex
    align-items stretch
  .window-control-box
    width 46px
    height 44px
    padding 0
    display flex
    align-items center
    justify-content center
    color var(--text)
    &:hover
      color var(--primary)
      background var(--main)
  .window-control-close:hover
    color #fff
    background var(--error)

@media (max-width: 1440px)
  .aigshell-topbar-actions
    gap 2px
  .aigshell-topbar-action
    width 30px
    padding 0
  .aigshell-topbar-action-label
    display none

@media (max-width: 900px)
  .aigshell-topbar
    padding-left 8px
  .aigshell-topbar-current
  .aigshell-topbar-separator
  .aigshell-topbar-dot
    display none
  .aigshell-topbar-brand
    gap 6px
