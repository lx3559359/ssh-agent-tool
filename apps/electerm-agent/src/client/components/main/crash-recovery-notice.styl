.crash-recovery-notice
  position absolute
  top 52px
  left 50%
  z-index 390
  width unquote('min(860px, calc(100vw - 176px))')
  min-height 52px
  transform translateX(-50%)
  display flex
  align-items center
  gap 12px
  box-sizing border-box
  padding 10px 12px
  color var(--text)
  background var(--main-light)
  border 1px solid var(--primary)
  border-radius 6px
  box-shadow 0 8px 24px rgba(0, 0, 0, .18)

.crash-recovery-notice-icon
  flex none
  color var(--primary)
  font-size 20px

.crash-recovery-notice-content
  min-width 0
  flex 1
  display flex
  flex-direction column
  gap 2px
  line-height 1.45
  strong
    color var(--text-light)
    font-size 13px
  span
    color var(--text)
    font-size 12px
    overflow-wrap anywhere

.crash-recovery-notice-actions
  flex none
  display flex
  align-items center
  justify-content flex-end
  gap 6px
  flex-wrap wrap

@media (max-width: 900px)
  .crash-recovery-notice
    width calc(100vw - 24px)
    align-items flex-start
    flex-wrap wrap
  .crash-recovery-notice-content
    width calc(100% - 36px)
  .crash-recovery-notice-actions
    width 100%
    justify-content flex-start
