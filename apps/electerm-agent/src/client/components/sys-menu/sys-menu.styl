.context-menu
  position relative
  box-sizing border-box
  min-width 220px
  width max-content
  max-width unquote('min(360px, calc(100vw - 16px))')
  color var(--sp-text)
  background var(--sp-surface-elevated)
  border 1px solid var(--sp-border)
  border-radius var(--sp-radius-overlay)
  box-shadow var(--sp-shadow-overlay)

.context-menu-inner
  min-width 0

.context-item
  -webkit-app-region no-drag
  position relative
  display grid
  grid-template-columns auto minmax(0, 1fr) auto
  align-items center
  gap 8px
  min-width 0
  min-height 32px
  padding 7px 12px
  line-height 1.4
  color var(--sp-text)
  white-space normal
  &:hover
    color var(--sp-text)
    background var(--sp-primary-soft)
    cursor pointer
  &.disabled
    color var(--sp-text-disabled)
    &:hover
      color var(--sp-text-disabled)
      background transparent
      cursor not-allowed
  &.zoom-item
    min-height 36px
    &:hover
      background transparent
    > *
      grid-column 1 / -1

.context-item-label
  grid-column 2
  min-width 0
  white-space normal
  overflow-wrap anywhere
  word-break normal

.context-sub-text
  grid-column 3
  min-width 0
  color var(--sp-text-muted)
  text-align right
  white-space normal
  overflow-wrap anywhere

.context-menu
  hr
    margin 5px 8px
    border none
    border-bottom 1px solid var(--sp-border)

.sub-context-menu
  display none
  box-sizing border-box
  min-width 200px
  width max-content
  max-width unquote('min(360px, calc(100vw - 16px))')
  position absolute
  left 100%
  top 0
  z-index 1
  color var(--sp-text)
  background var(--sp-surface-elevated)
  border 1px solid var(--sp-border)
  border-radius var(--sp-radius-overlay)
  box-shadow var(--sp-shadow-overlay)
  max-height calc(100vh - 16px)
  overflow-x hidden
  overflow-y auto

.with-sub-menu
  &:hover
    .sub-context-menu
      display block

.sub-context-menu-item
  min-width 0
  padding 7px 12px
  cursor pointer
  white-space normal
  overflow-wrap anywhere
  word-break normal
  &:hover, &.active
    color var(--sp-text)
    background var(--sp-primary-soft)

.bookmarks-sub-context-menu
  width unquote('min(360px, calc(100vw - 16px))')
  padding 12px

.menu-control
  width 28px
  height 28px
  border-radius 30px
  color var(--text)
  font-size 16px
  text-align center
  display inline-block
  line-height 28px
  cursor pointer

.menu-logo
  display inline-block
  width 28px
  height 28px
  vertical-align middle
  color var(--text-disabled)
  &:hover
    color var(--text)
  svg
    fill currentColor
    width 100%
    height 100%
  img
    width 100%
    height 100%
    display block
