.server-status-modal
  .ant-modal-body
    max-height calc(100vh - 150px)
    min-height 560px
    overflow hidden
    display flex
    flex-direction column

.server-status-toolbar
  display flex
  align-items center
  gap 14px
  padding-bottom 12px

.server-status-endpoint
  min-width 0
  flex 1
  overflow hidden
  text-overflow ellipsis
  white-space nowrap
  color var(--text-light)
  font-weight 600

.server-status-endpoint span
  color var(--text-disabled)
  font-weight 400

.server-status-summary
  display grid
  grid-template-columns repeat(6, minmax(0, 1fr))
  border 1px solid var(--main-darker)
  border-radius 6px
  overflow hidden
  background var(--main)

.server-status-summary-item
  min-width 0
  padding 10px 12px
  border-right 1px solid var(--main-darker)

.server-status-summary-item:last-child
  border-right 0

.server-status-summary-item span
  display block
  color var(--text-disabled)
  font-size 12px

.server-status-summary-item strong
  display block
  margin-top 5px
  overflow hidden
  text-overflow ellipsis
  white-space nowrap
  color var(--text)
  font-size 14px

.server-status-content
  min-height 410px
  height calc(100vh - 330px)
  margin-top 10px
  overflow hidden

.server-status-content .ant-tabs
  height 100%

.server-status-content .ant-tabs-content-holder
.server-status-content .ant-tabs-content
.server-status-content .ant-tabs-tabpane
  height 100%
  min-height 0

.server-status-overview
  display grid
  grid-template-columns minmax(0, 1.25fr) minmax(340px, .75fr)
  gap 12px
  height 100%
  min-height 0

.server-status-overview-side
  display grid
  grid-template-rows minmax(170px, .8fr) minmax(180px, 1.2fr)
  gap 12px
  min-height 0

.server-status-two-columns
  display grid
  grid-template-columns 1fr 1fr
  grid-template-rows minmax(160px, .8fr) minmax(220px, 1.2fr)
  gap 12px
  height 100%
  min-height 0

.server-status-span-two
  grid-column 1 / -1

.server-status-section
  min-height 0
  display flex
  flex-direction column
  border 1px solid var(--main-darker)
  border-radius 6px
  overflow hidden
  background var(--main)

.server-status-section header
  flex none
  padding 9px 12px
  border-bottom 1px solid var(--main-darker)
  color var(--text)
  font-weight 600

.server-status-section-scroll
.server-status-platform-list
.server-status-raw-list
  min-height 0
  overflow-y auto

.server-status-platform-list
  height 100%

.server-status-platform
  border-bottom 1px solid var(--main-darker)

.server-status-platform:last-child
  border-bottom 0

.server-status-platform summary
  display flex
  align-items center
  gap 10px
  padding 10px 12px
  cursor pointer
  list-style-position inside

.server-status-platform summary strong
  min-width 0
  overflow hidden
  text-overflow ellipsis
  white-space nowrap

.server-status-platform-tags
  margin-left auto
  flex none
  display flex
  align-items center
  gap 4px
  flex-wrap wrap
  justify-content flex-end

.server-status-evidence
  padding 0 12px 8px 30px
  color var(--text-disabled)
  font-size 12px

.server-status-row
  display grid
  grid-template-columns minmax(150px, 1fr) minmax(100px, .7fr) minmax(120px, 1fr)
  gap 10px
  padding 7px 12px
  border-top 1px solid var(--main-darker)
  color var(--text-light)
  font-size 12px

.server-status-row.has-diagnostic
  grid-template-columns minmax(150px, 1fr) minmax(100px, .7fr) minmax(120px, 1fr) auto

.server-status-row span
  min-width 0
  overflow hidden
  text-overflow ellipsis
  white-space nowrap

.server-status-compact-list
  overflow-y auto

.server-status-alert
  display flex
  align-items flex-start
  gap 7px
  margin 8px 10px
  padding 8px 10px
  border-left 3px solid var(--warning)
  border-radius 4px
  background var(--main-light)
  color var(--text-light)
  font-size 12px
  line-height 1.5

.server-status-alert > span:nth-child(2)
  min-width 0
  flex 1

.server-status-alert button
  flex none

.server-status-alert.critical
  border-left-color var(--error)

.server-status-empty-ok
  padding 18px
  color var(--success)

.server-status-resource-block
  padding 12px
  color var(--text-light)
  line-height 2

.server-status-process-row
  grid-template-columns minmax(220px, 1.5fr) minmax(90px, .5fr) minmax(150px, .8fr)

.server-status-pre
  min-height 0
  margin 0
  padding 12px
  overflow auto
  white-space pre-wrap
  overflow-wrap anywhere
  color var(--text-light)
  background var(--main)
  font-size 12px

.server-status-raw-list
  height 100%
  border 1px solid var(--main-darker)
  border-radius 6px

.server-status-raw-probe
  border-bottom 1px solid var(--main-darker)

.server-status-raw-probe summary
  display flex
  align-items center
  gap 10px
  padding 10px 12px
  cursor pointer

.server-status-raw-probe summary span:last-child
  margin-left auto
  color var(--text-disabled)

.server-status-probe-message
  padding 8px 12px
  color var(--text-disabled)
  font-size 12px

.server-status-full-section
  height 100%

.server-status-loading-placeholder
  min-height 360px

.server-status-footer
  display flex
  justify-content space-between
  gap 12px
  padding-top 9px
  color var(--text-disabled)
  font-size 12px

.server-status-rule-help
  padding 10px 12px
  border 1px solid var(--main-darker)
  border-radius 6px
  background var(--main-light)
  color var(--text-light)
  line-height 1.6

.server-status-rule-form
  display grid
  grid-template-columns 1fr 1fr
  gap 12px
  margin 14px 0

.server-status-rule-form label
  min-width 0

.server-status-rule-form label span
  display block
  margin-bottom 5px
  color var(--text-light)
  font-size 12px

.server-status-rule-form button
  align-self end
  justify-self start

.server-status-rule-list
  max-height 260px
  overflow-y auto
  border-top 1px solid var(--main-darker)

.server-status-rule-row
  display flex
  align-items center
  gap 12px
  padding 10px 4px
  border-bottom 1px solid var(--main-darker)

.server-status-rule-row > div
  min-width 0
  flex 1

.server-status-rule-row strong
.server-status-rule-row span
  display block

.server-status-rule-row span
  margin-top 4px
  overflow hidden
  text-overflow ellipsis
  white-space nowrap
  color var(--text-disabled)
  font-size 12px

@media (max-width: 1100px)
  .server-status-modal
    .ant-modal-body
      min-height 500px
  .server-status-summary
    grid-template-columns repeat(3, minmax(0, 1fr))
  .server-status-summary-item:nth-child(3)
    border-right 0
  .server-status-summary-item:nth-child(-n+3)
    border-bottom 1px solid var(--main-darker)
  .server-status-overview
    grid-template-columns 1fr
    overflow-y auto
  .server-status-overview-side
    grid-template-rows minmax(180px, auto) minmax(180px, auto)

@media (max-width: 760px)
  .server-status-modal
    .ant-modal-body
      min-height 460px
  .server-status-toolbar
    align-items flex-start
    flex-direction column
  .server-status-summary
    grid-template-columns repeat(2, minmax(0, 1fr))
  .server-status-summary-item
    border-bottom 1px solid var(--main-darker)
  .server-status-two-columns
    display flex
    overflow-y auto
    flex-direction column
  .server-status-section
    min-height 180px
  .server-status-footer
    flex-direction column
  .server-status-rule-form
    grid-template-columns 1fr
  .server-status-row.has-diagnostic
    grid-template-columns minmax(120px, 1fr) minmax(80px, .7fr) auto
  .server-status-row.has-diagnostic > span:nth-child(3)
    display none
  .server-status-platform summary
    align-items flex-start
  .server-status-platform-tags
    max-width 70%
