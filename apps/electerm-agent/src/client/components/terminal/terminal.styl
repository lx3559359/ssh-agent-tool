
shellPilotTerminalBackground = #0E0F12
shellPilotTerminalForeground = #E6EDF7
shellPilotTerminalMutedForeground = #AAB6C8
shellPilotTerminalActiveForeground = #FFFFFF

.terms-box
  background shellPilotTerminalBackground
  position relative
.loading-wrapper
  padding 30px
  z-index 100
.term-search-box
  position absolute
  right 5px
  top 5px
  z-index 30

.terminal-control
  background shellPilotTerminalBackground
  color shellPilotTerminalForeground
  line-height 32px
  padding 0 10px
  .type-tab,
  .spliter,
  .sess-icon
    color shellPilotTerminalMutedForeground
  .type-tab:hover,
  .type-tab.active,
  .type-tab:focus-visible,
  .spliter:hover,
  .spliter:focus-visible,
  .sess-icon:hover,
  .sess-icon.active,
  .sess-icon:focus-visible
    color shellPilotTerminalActiveForeground
  .type-tab-line
    background shellPilotTerminalMutedForeground

.terms-box
  position relative
.term-wrap
  background shellPilotTerminalBackground
  position absolute

.vertical
  .term-wrap.not-first-term
    border-top 1px solid var(--main-lighter)
.horizontal
  .term-wrap.not-first-term
    border-left 1px solid var(--main-lighter)
.term-sftp-tabs
  margin-left 5px

#container
  .xterm
    background shellPilotTerminalBackground
  .xterm-viewport
    background-color shellPilotTerminalBackground !important
  .xterm-screen::before
    content ''
    position absolute
    top 0
    left 0
    width 100%
    height 100%
    background-repeat no-repeat
    background-position center
    background-color transparent !important

.terminal-normal-buffer
  position absolute
  left 0
  top 0
  width 100%
  background var(--main)
  color var(--text)
  box-shadow 0px 3px 3px 0px var(--main-lighter)
  z-index 66
  padding-bottom 32px
.terminal-normal-buffer-body
  overflow-y scroll
  max-height 300px
.terminal-normal-buffer-close
  cursor pointer
  font-size 14px
  color var(--text)
  &:hover
    color var(--text-light)
.terminal-normal-buffer-footer
  position absolute
  left 0
  top calc(100% - 32px)
  width 100%
  height 32px
  line-height 32px
  box-shadow 0px -3px 3px 0px var(--main)
  background var(--main-lighter)
.batch-input-wrap
  width calc(100% - 80px)

.terminal-suggestions-wrap
  position absolute
  z-index 100
  max-height 300px
  max-width 300px
  min-width 200px
  box-shadow 0px 0px 3px 3px var(--main-lighter)
  display flex
  flex-direction column
  background var(--main)
  border-radius 4px
  &.reverse .terminal-suggestions-list
    border-top 1px solid var(--main-lighter)
    border-bottom none

.terminal-suggestions-list
  flex 1
  overflow-x hidden
  overflow-y auto
  max-height 268px
  max-width 300px
  border-bottom 1px solid var(--main-lighter)

.terminal-suggestions-sticky
  flex-shrink 0
  height 32px
  padding 0 10px
  line-height 32px

.suggestion-item
  display flex
  align-items center
  padding 5px 10px
  cursor pointer
  color var(--text)
  &:hover
    background-color var(--main-lighter)
    .suggestion-delete
      visibility visible

.suggestion-command
  flex-grow 1
  white-space nowrap
  overflow hidden
  text-overflow ellipsis

.suggestion-type
  margin-left 5px
  font-size 0.8em
  color var(--text)
  &:hover
    color var(--success)

.suggestion-hint
  margin-left 5px
  font-size 0.8em
  color var(--text-light, #888)
  white-space nowrap
  overflow hidden
  text-overflow ellipsis
  max-width 150px

.suggestion-delete
  margin-left 5px
  visibility hidden

.term-search-bar
  position absolute
  right 0
  top 0
  bottom 0
  background transparent
  width 16px
.paste-text
  max-height 200px
  overflow-y scroll

.terminal-reconnect-overlay
  position absolute
  right 12px
  bottom 10px
  z-index 110
  display flex
  align-items center
  flex-wrap wrap
  gap 8px
  max-width calc(100% - 24px)
  padding 7px 9px
  border 1px solid var(--main-lighter)
  border-radius 4px
  background var(--main)
  box-shadow 0 2px 8px rgba(0, 0, 0, 0.28)
  color var(--text)
  font-size 12px
  line-height 20px
  pointer-events auto

.terminal-reconnect-message
  min-width 0
  overflow-wrap anywhere

.terminal-reconnect-actions
  display inline-flex
  flex-shrink 0
  gap 6px

  button
    min-height 24px
    padding 1px 8px
    border 1px solid var(--main-lighter)
    border-radius 4px
    background var(--main-lighter)
    color var(--text)
    cursor pointer
    font: inherit
    line-height 20px

    &:hover
      color var(--primary)
      border-color var(--primary)

    &:focus-visible
      outline 2px solid var(--primary)
      outline-offset 1px

.terminal-reconnect-failed
  border-color var(--error)

.terminal-reconnect-stopped
  color var(--text-light)

.terminal-error-handle
  position absolute
  left 0
  top 0
  z-index 100
  background var(--main)
  max-width calc(100% - 24px)

.terminal-error-tips
  margin 4px 0 0 18px
  padding 0
  color var(--text)
  line-height 20px
  font-size 12px
  overflow-wrap anywhere

.terminal-error-actions
  margin-top 8px

.terminal-fontsize-reset
  position absolute
  left 8px
  bottom 4px
