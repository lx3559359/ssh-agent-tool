
.animate-fast
  animation-duration .2s
.sidebar-panel
  position absolute
  left 0
  top 0
  bottom 0
  z-index 200
  width 0
  overflow-y scroll
  background var(--main)
  .item-list-unit:hover
    .list-item-remove
      display none !important
.sidebar-panel
  top 44px
.sidebar
  position absolute
  left 0
  top 44px
  width 72px
  z-index 100
  bottom 0
  background var(--sp-surface)
  border-right 1px solid var(--sp-border)

  .item-list
    padding-right 0
.sidebar-pin-top
  position absolute
  left 0
  right 0
  top 0
  height 112px
.sidebar-panel-bookmarks
.sidebar-panel-history
  position absolute
  left 0
  right 0
  top 112px
  bottom 0
  overflow hidden
  display flex
  flex-direction column
  .sidebar-inner
    flex 1
    display flex
    flex-direction column
    overflow hidden
    min-height 0
  .history-header
    flex-shrink 0
    display flex
    align-items center
    border-bottom 1px solid var(--main-darker)
    position sticky
    top 0
    z-index 10
    background var(--main)
    .history-clear-icon
      margin-left auto
      margin-right 0
      color var(--text-dark)
      &:hover
        color var(--error)
  .history-body
    flex 1
    overflow-y auto
    overflow-x hidden
.not-system-ui.is-mac
  .sidebar-bar
    margin-top 20px
.type-bookmarks
  .bookmarks-panel
    width 100%
.type-history
  .history-panel
    width 100%
.control-icon-text
  color var(--text)
  &:hover
    color var(--success)
.control-icon-wrap
  width 100%
  padding 8px 0
  border 0
  appearance none
  text-align center
  font inherit
  color inherit
  background transparent
  cursor pointer
  &.active
    .control-icon
      color var(--sp-primary)
    .control-icon-label
      color var(--sp-primary)
      font-weight 650
  .control-icon-main
    display flex
    flex-direction column
    align-items center
    justify-content center
    gap 3px
    min-height 42px
  .control-icon
    color var(--sp-text-muted)
    cursor pointer
    &:hover
      color var(--sp-primary)
  .control-icon-label
    color var(--sp-text-muted)
    font-size 12px
    line-height 14px
    white-space nowrap
.sidebar .control-icon-wrap
  border-radius var(--sp-radius-control)
  box-shadow none
  transition background var(--sp-motion-fast) ease, box-shadow var(--sp-motion-fast) ease
  &:hover
    background var(--sp-surface-elevated)
    box-shadow var(--sp-shadow-control)
    .control-icon
    .control-icon-label
      color var(--sp-primary)
  &.active
    background var(--sp-primary-soft)
    box-shadow var(--sp-shadow-control)
.sidebar .control-icon-wrap:focus-visible
  outline 2px solid var(--sp-primary)
  outline-offset 2px
.sidebar-list
  position absolute
  left 72px
  top 44px
  bottom 0
  z-index 200
  width 0
  max-width calc(100vw - 72px)
  box-sizing border-box

.pinned
  .sidebar-list
    top 44px
    .sidebar-panel
      top 0
  .drag-handle
    display block
  .sidebar-panel
    .pinned
      color var(--success)
//btns
.btns
  background var(--sp-surface)
  border-color var(--sp-border)
  .control-icon-wrap
    padding 8px 0
  .open-about-icon
    color var(--sp-text-muted)
    &:hover
      color var(--sp-primary)
  .zoom-reset-icon
    color var(--sp-primary)
    &:hover
      color var(--sp-text)

.btns .upgrade-icon
  color var(--success)
.close-info-modal
  cursor pointer
  &:hover
    color var(--text-light)
.logo-filter
  filter invert(80%)
.sidebar-inner
  padding-right 8px
