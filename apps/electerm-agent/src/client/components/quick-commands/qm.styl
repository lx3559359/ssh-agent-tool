.qm-list-wrap
  flex 1
  min-height 0
  max-height none
  overflow-y auto
  overflow-x auto
  display grid
  grid-template-columns repeat(auto-fit, minmax(240px, 1fr))
  align-content start
  gap 10px
  padding 12px 2px 14px 0
  overscroll-behavior contain
.qm-wrap-tooltip
  background var(--main-light)
  position absolute
  left 72px
  right var(--quick-command-right-offset, 10px)
  z-index 89
  height 680px
  max-height calc(100vh - 88px)
  bottom 44px
  border 1px solid var(--main-darker)
  border-radius 14px
  box-shadow 0 -12px 28px rgba(0, 0, 0, .18)
  overflow hidden
  .pd2
    display flex
    flex-direction column
    height 100%
    min-height 0

.qm-pinned
  .qm-wrap-tooltip
    height 300px
  .qm-list-wrap
    max-height 210px

.qm-search-input
  max-width 260px
@media (max-width: 500px)
  .qm-search-input
    width 100px

.item-list-unit.dragover
  border: 1px dashed var(--primary)
.qm-item-dragover
  border-left 2px solid var(--primary)
.qm-field-dragging
  opacity 0.4
.qm-field-dragover
  border-top 2px solid var(--primary)
.qm-label-select
  min-width 120px

.qm-flex
  gap 8px
  margin-top 10px

.qm-panel-head
  gap 12px
  padding-bottom 8px
  border-bottom 1px solid var(--main-darker)

.qm-panel-title
  color var(--text-light)
  font-size 15px
  font-weight 700

.qm-panel-subtitle
  margin-top 3px
  color var(--text-dark)
  font-size 12px

.qm-panel-count
  flex 0 0 auto
  padding 2px 8px
  border 1px solid var(--main-darker)
  border-radius 999px
  color var(--primary)
  background var(--main-light)
  font-size 12px
  font-weight 650

.qm-item
  height 132px
  width 100%
  min-width 0
  max-width none
  margin 0 !important
  padding 9px 10px
  text-align left
  white-space normal
  border-color var(--main-darker)
  border-radius 12px
  background var(--main)
  vertical-align top
  box-shadow inset 0 1px 0 rgba(255, 255, 255, .04)
  &:hover
    border-color var(--primary)
    background var(--main-light)
  .ant-btn-icon
    display none

.qm-item-content
  display grid !important
  grid-template-rows auto minmax(34px, auto) minmax(34px, auto) auto
  align-items start
  gap 4px
  width 100%
  min-width 0
  height 100%

.qm-item-head
  display flex
  align-items flex-start
  justify-content space-between
  gap 8px
  width 100%
  min-width 0

.qm-item-title
  display -webkit-box
  min-width 0
  overflow hidden
  -webkit-box-orient vertical
  -webkit-line-clamp 2
  color var(--text-light)
  font-size 13px
  font-weight 700
  line-height 18px
  text-overflow ellipsis
  white-space normal
  word-break normal
  overflow-wrap anywhere

.qm-item-desc
  display -webkit-box
  overflow hidden
  -webkit-box-orient vertical
  -webkit-line-clamp 2
  color var(--text)
  font-size 12px
  line-height 17px

.qm-item-meta
  display flex !important
  flex-direction row !important
  flex-wrap wrap
  gap 4px
  color var(--text-dark)
  font-size 11px
  line-height 16px
  align-self end

.qm-item-pill
  display inline-flex
  align-items center
  height 18px
  padding 0 6px
  border 1px solid var(--main-darker)
  border-radius 999px
  color var(--text-dark)
  background var(--main)

.qm-item-pill-warn
  border-color var(--warn)
  color var(--warn)

.qm-item-usage
  display -webkit-box
  overflow hidden
  -webkit-box-orient vertical
  -webkit-line-clamp 2
  color var(--text-dark)
  font-size 11px
  line-height 16px

.qm-command-modal-desc
  margin-bottom 10px
  color var(--text)
  line-height 1.7
  div + div
    color var(--text-dark)

.qm-command-modal
  top 24px
  max-height calc(100vh - 48px)
  padding-bottom 0
  .ant-modal-content
    display flex
    flex-direction column
    max-height calc(100vh - 48px)
    overflow hidden
  .ant-modal-header,
  .ant-modal-footer
    flex 0 0 auto
  .ant-modal-body
    min-height 0
    overflow-y auto

.qm-command-modal-context
  display inline-flex
  align-items center
  margin-bottom 6px
  padding 2px 8px
  border 1px solid var(--main-darker)
  border-radius 999px
  color var(--primary)
  background var(--main)
  font-size 12px

.qm-command-modal-tips
  margin 0 0 10px 0
  padding 10px 12px
  border 1px solid var(--main-darker)
  border-radius 10px
  background var(--main)

.qm-command-modal-tips-title
  margin-bottom 6px
  color var(--text-light)
  font-weight 700

.qm-command-modal-tip
  color var(--text)
  font-size 12px
  line-height 1.7
  &:before
    content '• '
    color var(--primary)

.qm-command-param-section
  margin 0 0 12px 0
  padding 12px
  border 1px solid var(--primary)
  border-radius 12px
  background var(--main-light)
  box-shadow inset 0 1px 0 rgba(255, 255, 255, .04)

.qm-command-param-title
  margin-bottom 8px
  color var(--text-light)
  font-weight 700

.qm-command-param-grid
  display grid
  grid-template-columns repeat(2, minmax(0, 1fr))
  gap 10px 12px

.qm-command-param-item
  min-width 0

.qm-command-param-label
  margin-bottom 4px
  color var(--text-light)
  font-size 12px
  font-weight 650

.qm-command-param-control
  width 100%

.qm-command-param-help
  margin-top 4px
  color var(--text-dark)
  font-size 11px
  line-height 1.5

.qm-command-preview-label
  margin 10px 0 6px
  padding-top 10px
  border-top 1px solid var(--main-darker)
  color var(--text-light)
  font-size 12px
  font-weight 700

.qm-command-preview-toggle
  margin-top 4px
  border-radius 8px

.qm-command-preview-toggle-inline
  margin-top 0
  margin-bottom 6px

.qm-command-preview-wrap
  margin-top 8px

.qm-network-probe
  margin-bottom 10px
  padding 10px 12px
  border 1px solid var(--primary)
  border-radius 8px
  background var(--main-light)

.qm-network-probe-error
  border-color var(--warn)

.qm-network-probe-title
  color var(--text-light)
  font-size 12px
  font-weight 700

.qm-network-probe-status
  margin-top 4px
  color var(--text)
  font-size 12px

.qm-network-probe-values
  display flex
  flex-wrap wrap
  gap 4px 14px
  margin-top 5px
  color var(--text)
  font-size 12px

.qm-target-discovery
  margin-bottom 10px
  padding 10px 12px
  border 1px solid var(--primary)
  border-radius 8px
  background var(--main-light)

.qm-target-discovery-error
  border-color var(--warn)

.qm-target-discovery-title
  color var(--text-light)
  font-size 12px
  font-weight 700

.qm-target-discovery-status
  margin-top 4px
  color var(--text)
  font-size 12px
  line-height 1.5

.qm-rollback-preview
  margin 0 0 10px
  padding 10px 12px
  border 1px solid var(--success)
  border-radius 8px
  color var(--text)
  background var(--main)
  font-size 12px
  line-height 1.6

.qm-rollback-preview-disabled
  border-color var(--warn)

.qm-rollback-preview-head
  display flex
  align-items center
  justify-content space-between
  gap 12px
  margin-bottom 4px

.qm-rollback-preview-title
  color var(--text-light)
  font-weight 700

.qm-rollback-preview-path
  margin-top 3px
  color var(--text-dark)
  overflow-wrap anywhere

.qm-rollback-record
  display flex
  align-items center
  justify-content space-between
  gap 12px
  margin 10px 0
  padding 10px 12px
  border 1px solid var(--warn)
  border-radius 8px
  background var(--main-light)

.qm-rollback-record-title
  color var(--text-light)
  font-size 13px
  font-weight 700

.qm-rollback-record-desc,
.qm-rollback-record-path
  margin-top 2px
  color var(--text-dark)
  font-size 11px

.qm-rollback-record-path
  overflow-wrap anywhere

@media (max-width: 768px)
  .qm-flex
    flex-direction column
    align-items flex-start
  .qm-search-input
    max-width none
    width 100%
  .qm-label-select
    width 100%
  .qm-command-param-grid
    grid-template-columns 1fr
  .qm-rollback-record
    align-items flex-start
    flex-direction column
