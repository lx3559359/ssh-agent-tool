.right-side-panel
  position absolute
  right 0
  top 44px
  bottom 0
  z-index 320
  display flex
  flex-direction column
  background var(--main-light)
  color var(--text)
  border-left 1px solid var(--main-darker)
  &.right-side-panel-pinned
    top 44px

  .drag-handle
    left 0
    right auto
    display block

.right-panel-title
  flex 0 0 auto
  min-height 68px
  gap 10px
  border-bottom 1px solid var(--main-darker)
  background var(--main-light)
  box-shadow 0 1px 0 var(--main)

.right-panel-title-main
  min-width 0
  flex 1
  display flex
  flex-direction column
  gap 7px

.right-panel-title-text
  display block
  white-space nowrap
  overflow hidden
  text-overflow ellipsis
  color var(--text-light)
  font-size 15px
  font-weight 650

.right-panel-subtitle
  margin-top 2px
  color var(--text-dark)
  font-size 12px
  white-space nowrap
  overflow hidden
  text-overflow ellipsis

.right-panel-ai-selects
  width 100%
  max-width none
  min-width 0
  overflow hidden
  .ant-select
    min-width 0

.right-panel-ai-config-card
  padding 5px
  border 1px solid var(--main-darker)
  border-radius 7px
  background var(--main)
  box-shadow inset 0 1px 0 rgba(255, 255, 255, .04)

.right-panel-ai-profile-select,
.right-panel-ai-model-select
  flex 1 1 0
  width 100%
  .ant-select-selector
    min-height 24px
    border-color var(--main-darker) !important
    background var(--main) !important
    color var(--text) !important
  .ant-select-selection-item
    color var(--text)
    font-size 12px
    line-height 22px

.right-panel-ai-profile-select
  flex-basis 44%

.right-panel-ai-model-select
  flex-basis 56%

.aigshell-ai-tag
  margin-right 6px
  border-color var(--primary)
  color var(--primary)
  background var(--main)

.right-panel-online,
.right-panel-model-status
  height 24px
  line-height 22px
  flex 0 0 auto
  border-color var(--success)
  color var(--success)
  background var(--main)
  display inline-flex
  align-items center
  gap 4px
  cursor pointer
  user-select none
  &.not-configured
    border-color var(--warn)
    color var(--warn)
  &.checking
    border-color var(--primary)
    color var(--primary)
  &.reachable
    border-color var(--primary)
    color var(--primary)
  &.pending
    border-color var(--warn)
    color var(--warn)
  &.available
    border-color var(--success)
    color var(--success)
  &.auth-error,
  &.model-error,
  &.quota-error,
  &.network-error
    border-color var(--danger)
    color var(--danger)
  &.stale
    border-color var(--warn)
    color var(--warn)
  &:focus-visible
    outline 1px solid var(--primary)
    outline-offset 2px

.right-panel-model-status-refresh
  font-size 11px

.right-panel-model-latency
  padding-left 4px
  border-left 1px solid currentColor
  font-size 11px
  line-height 1
  opacity .86

.right-side-panel-controls
  color var(--text)
  font-size 15px
  &:hover
    color var(--primary)
    cursor pointer
  &.right-side-panel-pin
    &.pinned
      color var(--success)

.right-panel-title-controls
  flex 0 0 auto
  gap 6px
  padding-top 2px

.right-side-panel-content
  flex 1 1 auto
  min-height 0
  padding 12px
  overflow-y auto
  position static

.right-side-panel-content-ai
  overflow hidden
  display flex
  flex-direction column
  border-top 1px solid var(--main)

.animate-fast
  animation-duration .2s
