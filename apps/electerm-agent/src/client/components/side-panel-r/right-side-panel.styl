.right-side-panel
  position absolute
  right 0
  top 44px
  bottom 0
  z-index 320
  background var(--main-light)
  color var(--text)
  border-left 1px solid var(--main-darker)
  &.right-side-panel-pinned
    top 44px

  .drag-handle
    left 0
    right auto
    display block

.right-panel-title
  min-height 52px
  border-bottom 1px solid var(--main-darker)
  background var(--main-light)

.right-panel-title-main
  min-width 0
  flex 1

.right-panel-title-text
  display block
  color var(--text-light)
  font-size 15px
  font-weight 650

.right-panel-subtitle
  margin-top 2px
  color var(--text-dark)
  font-size 12px
  white-space nowrap
  overflow hidden
  text-overflow ellipsis

.aigshell-ai-tag
  margin-right 6px
  border-color var(--primary)
  color var(--primary)
  background var(--main)

.right-panel-online
  height 24px
  line-height 22px
  border-color var(--success)
  color var(--success)
  background var(--main)
  &.not-configured
    border-color var(--warn)
    color var(--warn)

.right-side-panel-controls
  color var(--text)
  font-size 15px
  &:hover
    color var(--primary)
    cursor pointer
  &.right-side-panel-pin
    &.pinned
      color var(--success)

.right-side-panel-content
  padding 10px
  overflow-y auto
  position absolute
  left 0
  top 53px
  right 0
  bottom 0

.right-side-panel-content-ai
  overflow hidden
  display flex
  flex-direction column

.animate-fast
  animation-duration .2s
