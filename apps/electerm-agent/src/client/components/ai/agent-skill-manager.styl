.agent-skill-manager
  color var(--text)
  min-width 0
  max-height min(76vh, 780px)
  overflow-y auto

.agent-skill-manager-actions
  position sticky
  top 0
  z-index 2
  width 100%
  padding 8px 0 12px
  background var(--main-light)

.agent-skill-manager-body
  display grid
  grid-template-columns minmax(210px, 0.7fr) minmax(0, 2.3fr)
  gap 14px
  min-width 0

.agent-skill-manager-list
  min-width 0
  max-height 65vh
  overflow-y auto
  border 1px solid var(--border)
  border-radius 6px
  padding 8px

  .ant-list-item
    cursor pointer
    padding 10px 8px

    &.is-selected
      background var(--sp-primary-soft)

.agent-skill-editor
  display grid
  grid-template-columns minmax(150px, 0.6fr) minmax(280px, 1.7fr) minmax(190px, 0.8fr)
  gap 12px
  min-width 0

.agent-skill-editor-files,
.agent-skill-editor-content,
.agent-skill-editor-evidence
  min-width 0
  max-height 65vh
  overflow auto
  border 1px solid var(--border)
  border-radius 6px
  padding 10px

.agent-skill-editor-toolbar
  width 100%
  justify-content space-between
  margin-bottom 8px

.agent-skill-editor-evidence
  pre
    white-space pre-wrap
    overflow-wrap anywhere
    font-size 12px

.agent-skill-create-modal
  max-height min(78vh, 820px)
  overflow-y auto
  min-width 0

.agent-skill-create-conversation
  max-height 160px
  overflow-y auto
  margin-bottom 10px
  padding 8px
  border 1px solid var(--border)
  border-radius 6px

.agent-skill-create-message
  margin-bottom 6px
  overflow-wrap anywhere

  &.assistant
    color var(--text-secondary)

.agent-skill-create-actions,
.agent-skill-create-status
  width 100%
  margin-top 10px

.agent-skill-draft-review
  min-width 0
  margin-top 14px

  > .ant-list
    max-height 150px
    overflow-y auto

  > .agent-skill-editor
    margin-top 12px

@media (max-width: 820px)
  .agent-skill-create-modal
    max-height 80vh

  .agent-skill-manager-body
    display block

  .agent-skill-manager-list
    max-height 180px
    margin-bottom 12px

  .agent-skill-editor
    grid-template-columns 150px minmax(0, 1fr)

  .agent-skill-editor-evidence
    grid-column 1 / -1
    max-height none

@media (max-width: 560px)
  .agent-skill-editor
    display block

  .agent-skill-editor-files,
  .agent-skill-editor-content,
  .agent-skill-editor-evidence
    max-height none
    margin-bottom 10px
