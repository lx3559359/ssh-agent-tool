.ai-chat-container
  height 100%
  display flex
  flex-direction column

.ai-chat-history
  flex 1 1 auto
  display flex
  flex-direction column
  min-height 0
  padding 0 2px
  overflow hidden
  &::-webkit-scrollbar
    width 0
.ai-history-wrap
  width 100%
  height 100%
  flex 1 1 auto
  min-height 0
  overflow-y auto
  overflow-x hidden
  padding-right 4px

.chat-history-item
  position relative
  content-visibility auto
  contain-intrinsic-size auto 220px
  > .ai-stop-icon-square
    position absolute
    bottom 8px
    right 8px
    z-index 10
  .code-block
    border 1px dashed var(--main-darker)
    padding 5px
    border-radius 3px
    pre
      margin-bottom 0
    // .code-block-actions
    //   display block
    // &:hover
    //   .code-block-actions
    //     display block

.ai-stream-output
  max-height none
  overflow visible

.ai-stream-plain-output
  margin 0
  white-space pre-wrap
  overflow-wrap anywhere
  font-family inherit

.ai-chat-input
  position relative
  flex 0 0 auto
  margin-top 10px
  padding-top 0

  .ant-input
    padding 10px 44px 34px 10px
    border-color var(--main-darker)
    border-radius 8px
    background var(--main-light)
    color var(--text)
    resize none
  .ai-chat-terminals > .ant-flex:first-child
    min-width 0
    flex-wrap nowrap
    overflow-x auto
    &::-webkit-scrollbar
      height 0


  .ai-chat-terminals
    position absolute
    bottom 6px
    left 8px
    right 8px
    background transparent
    z-index 1
    font-size 12px

.ai-context-actions
  display flex
  flex-wrap wrap
  gap 4px
  max-height 56px
  overflow-y auto
  margin-bottom 6px

.ai-context-action
  display inline-flex
  align-items center
  gap 4px
  height 24px
  padding 0 8px
  border 1px solid var(--main-darker)
  border-radius 6px
  background var(--main-light)
  color var(--text)
  font-size 12px
  line-height 22px
  cursor pointer
  white-space nowrap
  &:hover
    color var(--primary)
    border-color var(--primary)
    background var(--main)

.ai-attachment-queue
  display flex
  flex-wrap wrap
  gap 4px
  max-height 58px
  overflow-y auto
  margin-bottom 6px

.ai-attachment-chip
  display inline-flex
  align-items center
  gap 4px
  max-width 100%
  height 24px
  padding 0 7px
  border 1px solid var(--main-darker)
  border-radius 6px
  background var(--main-light)
  color var(--text)
  font-size 12px
  cursor default
  span
    max-width 160px
    overflow hidden
    text-overflow ellipsis
    white-space nowrap

.ai-attachment-remove
  cursor pointer
  color var(--text-dark)
  &:hover
    color var(--danger)

.ai-attachment-upload-button
  display inline-flex
  align-items center
  justify-content center
  gap 4px
  height 24px
  padding 0 8px
  border 1px solid var(--primary)
  border-radius 6px
  background var(--main)
  color var(--primary)
  font-size 12px
  line-height 22px
  cursor pointer
  white-space nowrap
  &:hover
    background var(--primary)
    color var(--primary-contrast)

.ai-config-inline-help
  display grid
  grid-template-columns 72% 28%
  gap 8px
  color var(--text-dark)
  line-height 1.55
  b
    color var(--text)
  @media (max-width: 780px)
    grid-template-columns 1fr

.code-block
  width 100%
  pre
    white-space pre-wrap
    word-wrap break-word
    overflow-x auto
    max-width 100%
  code
    white-space pre-wrap
    word-break break-all

.send-to-ai-icon.disabled
  opacity 0.4
  cursor not-allowed

.send-to-ai-icon
  display inline-flex
  align-items center
  justify-content center
  width 28px
  height 28px
  border-radius 7px
  color var(--primary-contrast)
  background var(--primary)
  font-size 14px
  &:hover
    color var(--primary-contrast)
    opacity .85

.clear-ai-icon
  position relative
  &::after
    content '×'
    position absolute
    font-size 12px
    top 8px
    right -4px
    font-weight bold

.ai-stop-icon-square
  width 20px
  height 20px
  border-radius 2px
  display flex
  align-items center
  justify-content center
  font-size 10px

.ai-history-item-title
  display flex
  align-items flex-start
  gap 8px
  width 100%
  .ai-stop-icon-square
    margin-left auto

.ai-history-item-prompt
  flex 1
  min-width 0
  white-space pre-wrap
  overflow-wrap anywhere
  word-break break-word
  line-height 1.55

.ai-history-item-actions
  display inline-flex
  align-items center
  flex none
  padding-top 2px
  color var(--text-dark)

.agent-tool-calls
  margin 8px 0

.agent-tool-call-card
  border 1px solid var(--main-darker)
  border-radius 4px
  margin-bottom 6px
  font-size 13px

.agent-tool-header
  display flex
  align-items center
  padding 6px 8px
  gap 6px

.agent-tool-name
  font-weight 500

.agent-tool-tag
  margin-left auto

.agent-tool-status-running
  color #1890ff
  animation spin 1s linear infinite

.agent-tool-status-completed
  color #52c41a

.agent-tool-status-error
  color #ff4d4f

.agent-tool-detail
  padding 0 8px 8px
  border-top 1px solid var(--main-darker)

.agent-tool-args
  margin-top 6px

.agent-tool-result
  margin-top 6px

.agent-tool-label
  font-weight 500
  margin-bottom 4px
  font-size 12px
  color var(--text-color-2)

.agent-tool-pre
  background var(--main-dark)
  padding 6px 8px
  border-radius 3px
  font-size 12px
  max-height 200px
  overflow-y auto
  white-space pre-wrap
  word-break break-all
  margin-bottom 0

.agent-tool-running
  border-color #1890ff

.agent-tool-completed
  border-color #52c41a

.agent-tool-error
  border-color #ff4d4f

@keyframes spin
  from
    transform rotate(0deg)
  to
    transform rotate(360deg)

// ShellPilot model API configuration card
.sp-ai-endpoint-preview
  max-width 100%
  overflow-wrap anywhere
  word-break break-word

.sp-ai-config-form
  width 100%
  max-width 980px
  min-width 0
  margin 0 auto 16px
  padding 24px
  box-sizing border-box
  color var(--sp-text)
  background var(--sp-surface)
  .ant-form-item
  .ant-form-item-control
  .ant-form-item-control-input
  .ant-form-item-control-input-content
  .ant-space
  .ant-space-item
  .ant-space-compact
  .ant-select
  .ant-input
  .ant-input-affix-wrapper
  textarea
  input
    min-width 0
    max-width 100%
  .ant-form-item-label > label
    max-width 100%
    height auto
    white-space normal
    overflow-wrap break-word
    word-break normal
  .ant-form-item-extra
  .ant-form-item-explain
  a
    max-width 100%
    overflow-wrap anywhere
    word-break break-word
  .ant-space-horizontal
    max-width 100%
    flex-wrap wrap
  .ant-btn
    max-width 100%
    height auto
    min-height 32px
  .ant-btn > span
    white-space normal
    overflow-wrap break-word
    word-break normal
    text-overflow clip
  .border
    background var(--sp-surface-subtle)
    border-color var(--sp-border) !important
    border-radius var(--sp-radius-control)

@media (max-width: 680px)
  .sp-ai-config-form
    padding 14px
    .ant-space-compact
      display flex
      flex-wrap wrap
      gap 8px
      > *
        flex 1 1 100% !important
        width 100% !important
        border-radius var(--sp-radius-control) !important
    .ant-space-horizontal
      width 100%
      > .ant-space-item
        flex 1 1 100%
        width 100%
