.bookmark-import-strategy-options
  display grid
  color var(--text)
  gap 8px

  p
    margin 0 0 4px

.bookmark-import-strategy-option
  display flex
  align-items flex-start
  gap 10px
  padding 9px 10px
  border 1px solid var(--main-darker)
  border-radius 4px
  cursor pointer

  input
    margin-top 3px

  span
    display grid
    gap 2px

  small
    color var(--text-light, #666)
    line-height 1.45
