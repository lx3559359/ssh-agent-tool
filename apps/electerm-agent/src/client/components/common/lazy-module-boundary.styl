.lazy-module-error
  position relative
  z-index 1200
  display flex
  align-items center
  gap 10px
  min-width 260px
  max-width 520px
  margin 12px auto
  padding 12px
  border 1px solid var(--main-darker)
  border-radius 6px
  background var(--main-light)
  color inherit
  box-shadow 0 8px 24px rgba(0, 0, 0, 0.16)
.lazy-module-error-icon
  flex 0 0 auto
  color #d48806
.lazy-module-error-copy
  display flex
  flex 1 1 auto
  min-width 0
  flex-direction column
  gap 2px
  strong
    font-size 13px
  span
    font-size 12px
    line-height 1.5
    white-space normal
