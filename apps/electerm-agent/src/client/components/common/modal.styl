.custom-modal-wrap
  position fixed
  top 0
  left 0
  right 0
  bottom 0
  overflow auto
  outline 0

.custom-modal-mask
  position fixed
  top 0
  left 0
  right 0
  bottom 0
  background rgba(0, 0, 0, 0.45)

.custom-modal-container
  position relative
  display flex
  align-items flex-start
  justify-content center
  min-height 100%
  padding 24px
  word-break break-word

.custom-modal-content
  position relative
  min-width 0
  color var(--sp-text)
  background var(--sp-surface-elevated)
  border 1px solid var(--sp-border-strong)
  border-radius var(--sp-radius-overlay)
  box-shadow inset 0 1px 0 var(--sp-highlight-top, rgba(255, 255, 255, .35)), var(--sp-shadow-overlay)
  margin-top 50px
  max-width calc(100vw - 48px)

.custom-modal-header
  display flex
  align-items center
  justify-content space-between
  min-width 0
  padding 16px 24px
  border-bottom 1px solid var(--sp-border)

.custom-modal-title
  min-width 0
  font-size 16px
  font-weight 600
  color var(--sp-text)
  line-height 1.5
  flex 1
  white-space normal
  overflow-wrap anywhere
  word-break normal

.custom-modal-close
  display flex
  align-items center
  justify-content center
  width 32px
  height 32px
  padding 0
  margin-left 8px
  background transparent
  border none
  border-radius 4px
  color var(--text)
  cursor pointer
  transition background-color 0.2s
  &:hover
    background var(--main-darker)
  &:focus
    outline none
  &:focus-visible
    outline 2px solid var(--sp-primary)
    outline-offset 2px
    background var(--sp-primary-soft)

.custom-modal-body
  min-width 0
  padding 0 24px 24px 24px
  color var(--sp-text)
  white-space normal
  overflow-wrap anywhere
  word-break normal

.custom-modal-footer
  padding 12px 24px
  border-top 1px solid var(--sp-border)
  text-align right

.custom-modal-footer-buttons
  display flex
  flex-wrap wrap
  justify-content flex-end
  gap 8px

.custom-modal-ok-btn,
.custom-modal-cancel-btn
  padding 6px 16px
  border none
  border-radius 4px
  cursor pointer
  font-size 14px
  transition background-color 0.2s

.custom-modal-ok-btn
  background var(--primary)
  color var(--primary-contrast)

.custom-modal-cancel-btn
  background var(--main)
  color var(--text)
