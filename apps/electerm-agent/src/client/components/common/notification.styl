.notification-container
  position fixed
  bottom 20px
  right 20px
  z-index 9999

.notification
  box-sizing border-box
  min-width 0
  color var(--sp-text)
  background var(--sp-surface-elevated)
  border 1px solid var(--sp-border-strong)
  border-radius var(--sp-radius-overlay)
  margin-bottom 10px
  padding 12px 16px
  box-shadow inset 0 1px 0 var(--sp-highlight-top), var(--sp-shadow-overlay)
  width unquote('min(400px, calc(100vw - 32px))')
  position relative

.notification-content
  min-width 0
  width 100%

.notification-message
  font-weight bold

.notification-title
  min-width 0
  white-space normal
  overflow-wrap anywhere
  word-break normal
  padding 0 30px 0 20px

.notification-icon
  font-size 16px
  position absolute
  left 12px
  top 10px

.notification-description
  min-width 0
  white-space normal
  overflow-wrap anywhere
  word-break normal
  max-height 200px
  overflow auto
  padding 10px 0 0 0

.notification-close
  position absolute
  top 12px
  right 12px
  background none
  border none
  color var(--text-dark)
  font-size 18px
  cursor pointer
  padding 0
  &:hover
    color var(--text)

.notification-copy-icon
  cursor pointer
  font-size 14px
  position absolute
  right 10px
  top 45px
  margin-left 8px
  display none
.notification-message .notification-copy-icon
  right 38px
  top 14px
.notification-message:hover .notification-copy-icon,
.notification-description:hover .notification-copy-icon
  display inline-block
