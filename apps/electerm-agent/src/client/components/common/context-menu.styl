.shellpilot-context-menu
  box-sizing border-box
  max-width unquote('min(360px, calc(100vw - 16px))')
  max-height calc(100vh - 16px)

.shellpilot-context-menu.ant-dropdown
  min-width 220px
  width max-content
  overflow-x hidden
  overflow-y hidden
  border-radius var(--sp-radius-overlay)

.shellpilot-context-menu.ant-popover
  overflow-x hidden
  overflow-y auto

.shellpilot-context-menu.shellpilot-context-menu
  .ant-dropdown-menu
    box-sizing border-box
    min-width 220px
    width max-content
    max-width unquote('min(360px, calc(100vw - 16px))')
    max-height calc(100vh - 16px)
    overflow-x hidden
    overflow-y auto
    color var(--sp-text)
    background var(--sp-surface-elevated)
    border 1px solid var(--sp-border)
    border-radius var(--sp-radius-overlay)
    box-shadow var(--sp-shadow-overlay)

  .ant-dropdown-menu-item,
  .ant-dropdown-menu-submenu-title
    display grid
    grid-template-columns auto minmax(0, 1fr) auto
    align-items center
    gap 8px
    min-width 0
    min-height 34px
    padding 7px 12px
    color var(--sp-text)
    white-space normal

  .ant-dropdown-menu-title-content,
  .ant-dropdown-menu-item-label,
  .ant-dropdown-menu-item-extra
    min-width 0
    white-space normal
    overflow-wrap anywhere
    word-break normal

  .ant-dropdown-menu-item > .ant-dropdown-menu-title-content
    grid-column 2 / -1

  .ant-dropdown-menu-title-content-with-extra
    display grid
    grid-template-columns minmax(0, 1fr) auto
    align-items center
    gap 8px
    width auto

  .ant-dropdown-menu-item-extra
    color var(--sp-text-muted)
    margin-inline-start 0
    text-align right

  .ant-dropdown-menu-item:hover,
  .ant-dropdown-menu-submenu-title:hover,
  .ant-dropdown-menu-item-active,
  .ant-dropdown-menu-submenu-active > .ant-dropdown-menu-submenu-title
    color var(--sp-text)
    background var(--sp-primary-soft)

  .ant-dropdown-menu:focus-visible .ant-dropdown-menu-item-active
    outline 2px solid var(--sp-primary)
    outline-offset -2px

  .ant-dropdown-menu-item-divider
    margin 5px 8px
    background var(--sp-border)

  .ant-dropdown-menu .ant-dropdown-menu-item-danger:not(.ant-dropdown-menu-item-disabled)
    color var(--sp-danger)
    font-weight 600

  .ant-dropdown-menu .ant-dropdown-menu-item-danger:not(.ant-dropdown-menu-item-disabled):hover
    color var(--sp-danger)
    background var(--sp-primary-soft)

  .ant-dropdown-menu-item-disabled,
  .ant-dropdown-menu-submenu-disabled > .ant-dropdown-menu-submenu-title
    color var(--sp-text-disabled)
    background transparent
    opacity 1

  .ant-dropdown-menu-submenu-expand-icon
    position static
    grid-column 3
    align-self center
    color var(--sp-text-muted)

@media (max-width: 760px)
  .shellpilot-context-menu.shellpilot-context-menu.ant-dropdown-menu-submenu-popup
    inset-inline-start 8px !important
    inset-inline-end auto !important
    inset-block-start 8px !important
    inset-block-end auto !important

@media (max-height: 760px)
  .shellpilot-context-menu.shellpilot-context-menu.ant-dropdown:not(.ant-dropdown-menu-submenu-popup)
    inset-block-start 8px !important
    inset-block-end auto !important
