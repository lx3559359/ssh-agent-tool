
.item-list-wrap
  overflow-y scroll
  &::-webkit-scrollbar
    width 0
.list-item-edit
.list-item-apply
.list-item-remove
.list-item-bookmark
.list-item-duplicate
.list-item-autorun
  display none
  width 24px
  line-height 35px
  text-align center
  position absolute
  right 0
  top 0
.list-item-autorun
  right 24px

.list-item-title
  flex-grow: 1
  min-width 0
  white-space normal
  overflow visible
  overflow-wrap break-word
  word-break normal
  text-overflow clip
.item-list-unit
  display flex
  min-width 0
  position relative
  margin-bottom 1px
  cursor pointer
  line-height 1.8
  &.active
    background var(--sp-primary-soft)
    color var(--sp-text)
  &.current
    font-weight bold
  &:focus-within
    background var(--sp-primary-soft)
    color var(--sp-text)
    outline 2px solid var(--sp-primary)
    outline-offset -2px
  &:hover
    background var(--sp-primary-soft)
    color var(--sp-text)
    .list-item-title
      padding-right 84px
    .list-item-apply
    .list-item-edit
    .list-item-remove
    .list-item-bookmark
    .list-item-duplicate
    .list-item-autorun
      display block
.theme-item:hover
    .list-item-remove
      right 24px
.setting-tabs-setting
  .item-list-unit
    .list-item-remove
      display none

@media (max-width: 820px)
  .setting-tabs-setting
  .setting-tabs-terminal-themes
  .setting-tabs-quick-commands
  .setting-tabs-profile
    .setting-row-left
      .item-list
        display flex
        align-items center
        gap 10px
        width max-content
        min-width 100%
      .item-list > .pd1y
        flex 0 0 180px
        padding 0
      .item-list-wrap
        display flex
        flex-direction row
        flex 0 0 auto
        gap 4px
        overflow-x auto
        overflow-y hidden
      .item-list-unit
        flex 0 0 auto
        max-width 240px
        margin 0
  .setting-tabs-bookmarks
    .model-bookmark-tree-wrap
      display block
      height 100%
    .tree-list
      display flex
      flex-direction column
      min-height 0
    .item-list-wrap
      display block
      flex 1 1 auto
      min-height 0
      overflow-x hidden
      overflow-y auto
