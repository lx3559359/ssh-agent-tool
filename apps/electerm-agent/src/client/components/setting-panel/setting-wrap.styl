.setting-wrap
  --sp-setting-header-height 64px
  background var(--sp-page)
  color var(--sp-text)
  overflow-x hidden
  .custom-drawer-content-wrapper
  .custom-drawer-content
    background var(--sp-page)
    color var(--sp-text)
    min-width 0
    overflow-x hidden
  .custom-drawer-content
    display flex
    flex-direction column
    min-height 0
  .ant-btn
    height auto
    min-height 32px
    max-width 100%
  .ant-btn > span
    white-space normal
    overflow-wrap break-word
    text-overflow clip

.setting-header
  position sticky !important
  top 0
  z-index 10 !important
  flex 0 0 auto
  min-height var(--sp-setting-header-height)
  gap 10px !important
  padding 12px 20px !important
  background var(--sp-surface)
  border 1px solid var(--sp-border)
  border-radius var(--sp-radius-control)
  box-shadow inset 0 1px 0 var(--sp-highlight-top), var(--sp-shadow-control)
  > *
    min-width 0
  h2
    margin 0
    color var(--sp-text)
    white-space normal !important
    overflow-wrap break-word
    word-break normal
    text-overflow clip
  .setting-header-search
    position relative
    flex 1 1 240px
    width 100%
    max-width 320px
    > .ant-input-affix-wrapper
      width 100%
      max-width none !important
  .setting-header-search-toggle
    display none
  .setting-search-results
    position absolute
    top calc(100% + 6px)
    right 0
    left 0
    z-index 12
    display flex
    flex-direction column
    max-height min(320px, 52vh)
    padding 6px
    background var(--sp-surface)
    border 1px solid var(--sp-border)
    border-radius var(--sp-radius-control)
    box-shadow var(--sp-shadow-card)
    overflow-x hidden
    overflow-y auto
    button
      display flex
      align-items center
      gap 8px
      width 100%
      min-width 0
      min-height 36px
      padding 7px 10px
      color var(--sp-text)
      text-align left
      background transparent
      border 0
      border-radius var(--sp-radius-control)
      cursor pointer
      span
        min-width 0
        overflow-wrap break-word
      &:hover
      &:focus-visible
        color var(--sp-text)
        background var(--sp-primary-soft)
        outline 2px solid var(--sp-primary)
        outline-offset -2px
  .ant-select
    flex 0 1 180px
    max-width 220px
  .setting-header-auto-saved
    color var(--sp-text-muted)
    overflow-wrap break-word
    word-break normal

.setting-tabs
  position sticky
  top var(--sp-setting-header-height)
  z-index 9
  flex 0 0 auto
  min-width 0
  max-width 100%
  margin 0
  padding 8px 20px 0
  background var(--sp-page)
  overflow-x hidden
  .ant-tabs-nav
    width 100%
    min-width 0
    max-width 100%
    margin 0
    overflow-x hidden
    overflow-y hidden
  .ant-tabs-nav-wrap
    flex 1 1 auto
    min-width 0
    max-width 100%
    overflow-x auto
    overflow-y hidden
  .ant-tabs-nav-list
    width max-content
    white-space nowrap
  .ant-tabs-content-holder
    display none
  .ant-tabs-tab-active
    background var(--sp-primary-soft)
    border-radius var(--sp-radius-control)

.setting-tabs-setting
.setting-tabs-bookmarks
.setting-tabs-terminal-themes
.setting-tabs-quick-commands
.setting-tabs-profile
.setting-tabs-widgets
  flex 1 1 auto
  min-width 0
  min-height 0
  overflow hidden

.setting-col
  display grid
  grid-template-columns 226px minmax(0, 1fr)
  width 100%
  height 100%
  min-width 0
  min-height 0
  overflow hidden
  ::-webkit-scrollbar
    width 0

.setting-row
  position static
  box-sizing border-box
  min-width 0
  min-height 0

.setting-row-left
  display flex
  flex-direction column
  padding 16px 12px
  background var(--sp-surface-subtle)
  border-right 1px solid var(--sp-border)
  overflow-x hidden
  overflow-y auto
  .model-bookmark-tree-wrap
    flex 1
    display flex
    flex-direction column
    min-width 0
    min-height 0
    overflow hidden

.setting-row-right
  display flex
  flex-direction column
  min-width 0
  min-height 0
  padding 20px
  overflow-x hidden
  overflow-y hidden

.setting-col-content
  flex 1
  min-width 0
  min-height 0
  overflow-x hidden
  overflow-y auto

.setting-col-placeholder
  display flex
  flex 0 0 auto
  min-width 0
  justify-content flex-end
  .carbonads-wrap
    margin 8px 0 0

@media (max-width: 820px)
  .setting-wrap
    --sp-setting-header-height 64px
  .setting-header
    padding 10px 14px !important
    .setting-header-auto-saved
      display none
  .setting-tabs
    padding 6px 14px 0
  .setting-col
    display block
  .setting-row-left
    display block
    height 104px
    padding 8px 14px
    border-right 0
    border-bottom 1px solid var(--sp-border)
    overflow-x auto
    overflow-y hidden
  .setting-row-right
    height calc(100% - 104px)
    padding 14px
  .setting-col-content
    overflow-x hidden
    overflow-y auto
  .setting-tabs-bookmarks
    .setting-row-left
      height clamp(132px, 36vh, 190px)
      overflow-x hidden
    .setting-row-right
      height calc(100% - clamp(132px, 36vh, 190px))
  .setting-tabs-widgets
    overflow-x hidden
    overflow-y auto
    .setting-col
      height auto
      min-height 100%
      overflow visible
    .setting-row-left
      display block
      height auto
      min-height 0
      border-right 0
      border-bottom 1px solid var(--sp-border)
      overflow visible
    .setting-row-right
      height auto
      min-height 180px
      overflow visible
    .setting-col-content
      overflow visible

@media (max-width: 680px)
  .setting-wrap
    --sp-setting-header-height 148px
  .setting-header
    display flex !important
    flex-wrap wrap
    align-content flex-start
    align-items center !important
    min-height var(--sp-setting-header-height)
    gap 8px !important
    padding 10px 12px !important
    h2
      order 1
      flex 1 1 0
    .setting-header-search
      order 3
      display none
      flex 0 0 100%
      flex-basis 100%
      max-width none !important
      &.is-expanded
        display block
    .ant-select
      order 4
      flex 1 1 132px
      min-width 0 !important
      max-width 100%
    .ant-btn
      order 4
      flex 0 1 auto
      min-width 0
      height auto
      padding-inline 10px
    .setting-header-search-toggle
      order 1
      display inline-flex
      flex 0 0 auto
    > .ant-btn:last-child
      order 2
      flex 0 0 auto
      margin-left auto
  .setting-tabs
    padding-inline 12px
  .setting-row-left
    height 96px
    padding 6px 12px
  .setting-row-right
    height calc(100% - 96px)
    padding 12px

@media (max-width: 820px) and (max-height: 360px)
  .setting-header
    position static !important
  .setting-tabs
    position static
    top auto
  .setting-tabs-widgets
    flex 0 0 auto
  .setting-tabs-bookmarks
    overflow-x hidden
    overflow-y auto
    .setting-col
      height auto
      overflow visible
    .setting-row-left
      height 132px
      min-height 132px
    .setting-row-right
      height auto
      min-height 160px
