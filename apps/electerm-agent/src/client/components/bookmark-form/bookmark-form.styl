.mg24b
  margin-bottom 24px
.mg60b
  margin-bottom 60px
.compact-input input
  width 80px !important
.ssh-tunnels-host
  margin-bottom 0
.ip-item
   line-height 34px
  .item-item-use
    display none
.ip-item:hover
    .item-item-use
      display inline-block
.number-input
  min-width 210px

.tree-select-wrapper
  display flex
  flex-direction column
  height 100%
  overflow hidden

.tree-select-header
  flex-shrink 0

.tree-select-content
  flex 1
  overflow auto
  margin-top 8px

.bookmark-json-preview
  padding 12px
  max-height 300px
  overflow auto
  font-size 12px
  font-family monospace

// ShellPilot connection configuration surfaces
.sp-configuration-form
  width 100%
  max-width 100%
  min-width 0
  padding-bottom 104px
  box-sizing border-box
  color var(--sp-text)
  .ant-form-item
  .ant-form-item-control
  .ant-form-item-control-input
  .ant-form-item-control-input-content
  .ant-input
  .ant-input-affix-wrapper
  .ant-input-number
  .ant-select
  .ant-space
  textarea
  input
    min-width 0
    max-width 100%
  .ant-form-item-label > label
    max-width 100%
    height auto
    white-space normal
    overflow-wrap break-word
    word-break normal
  .ant-form-item-extra
  .ant-form-item-explain
  a
    max-width 100%
    overflow-wrap anywhere
    word-break break-word
  .ant-btn
    max-width 100%
    height auto
    min-height 32px
  .ant-btn > span
    white-space normal
    overflow-wrap break-word
    word-break normal
    text-overflow clip

.sp-configuration-form .sp-configuration-section
  min-width 0
  max-width 100%
  margin 0 0 16px
  padding 20px
  box-sizing border-box

.sp-configuration-form .sp-configuration-tabs
  min-width 0
  max-width 100%
  .ant-tabs-content-holder
  .ant-tabs-content
  .ant-tabs-tabpane
    min-width 0
    max-width 100%
  .ant-tabs-tab-btn
    white-space normal
    overflow-wrap break-word
    word-break normal

.sp-configuration-form .sp-configuration-actions
  position sticky
  bottom 0
  z-index 2
  margin 8px 0 0
  padding 12px 16px 4px
  background var(--sp-surface)
  border-top 1px solid var(--sp-border)
  box-shadow var(--sp-shadow-card)
  .ant-form-item-control
    min-width 0
  .sp-configuration-action-row
    display flex
    flex-wrap wrap
    align-items center
    gap 0 4px
    min-width 0
    margin 0

@media (max-width: 760px)
  .sp-configuration-form .sp-configuration-section
    padding 14px
    margin-bottom 12px
  .sp-configuration-form .sp-configuration-tabs
    min-width 0
    max-width 100%
    .ant-tabs-nav
      max-width 100%
    .ant-tabs-nav-wrap
      overflow-x auto !important
      overflow-y hidden
  .sp-configuration-form .sp-configuration-actions
    padding 10px 12px 2px
    .ant-form-item-control
      margin-inline-start 0 !important
      max-width 100%

@media (max-width: 480px)
  .sp-configuration-form
    padding-bottom 132px

@media (max-width: 760px) and (max-height: 520px)
  .sp-configuration-form
    padding-bottom 16px
  .sp-configuration-form .sp-configuration-actions
    position static
    bottom auto
    z-index auto
    box-shadow none
