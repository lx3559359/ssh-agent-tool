.main-footer
  background #f7f8fa
  height 36px
  position absolute
  left 72px
  right 0
  bottom 0
  z-index 200
  border-top 1px solid #dfe3ea
  color #374151
.pinned
  .main-footer
  .qm-wrap-tooltip
    left 372px

.terminal-footer-flex
  display flex
  align-items center
  height 100%
  .terminal-footer-unit .ant-select-selector .ant-select-selection-placeholder
    line-height 24px
.terminal-footer-unit
  margin-left 10px
  line-height 34px
  font-size 12px
  textarea.ant-input
    min-height 26px
    height 26px
    margin-bottom -2px
    resize none
    &::-webkit-scrollbar
      width 0

.terminal-footer-center
  flex-grow 1
.terminal-footer-info
  margin-right 10px
  line-height 34px
.terminal-footer-history
  display flex
  align-items center
.terminal-footer-qm
  // Q is now an icon-only button (5px internal padding); reduce left
  // margin so the history icon stays roughly equidistant from AI and Q
  margin-left 3px
.terminal-footer-status
  display flex
  align-items center
  gap 8px
  min-width 260px
  white-space nowrap
.terminal-footer-muted
  color #64748b
.terminal-footer-dot
  width 8px
  height 8px
  border-radius 50%
  background #aeb6c2
  &.online
    background #22c55e
.batch-input-outer
  .bi-full
    display none
  &.bi-show
    line-height 20px
    .bi-full
      display inline
    .bi-compact
      display none
.batch-input-holder
  width 100px
@media (max-width: 500px)
  .batch-input-outer
    &.bi-show
      position fixed
      left 100px
      right 0
      bottom 0
      z-index 100
      background var(--main)
