.main-footer
  background var(--sp-surface-elevated)
  height 36px
  position absolute
  left 72px
  right 0
  bottom 0
  z-index 200
  border-top 1px solid var(--sp-border)
  box-shadow 0 -3px 8px -6px var(--sp-border-strong)
  color var(--sp-text)
.pinned
  .main-footer
  .qm-wrap-tooltip
    left 372px

.terminal-footer-flex
  display flex
  align-items center
  height 100%
  min-width 0
  .terminal-footer-unit .ant-select-selector .ant-select-selection-placeholder
    line-height 24px
.terminal-footer-unit
  margin-left 10px
  line-height 34px
  font-size 12px
  textarea.ant-input
    min-height 26px
    height 26px
    margin-bottom -2px
    resize none
    &::-webkit-scrollbar
      width 0

.terminal-footer-center
  flex-grow 1
  min-width 0
.terminal-footer-info
  margin-right 10px
  line-height 34px
.terminal-footer-history
  display flex
  align-items center
.terminal-footer-qm
  // Q is now an icon-only button (5px internal padding); reduce left
  // margin so the history icon stays roughly equidistant from AI and Q
  margin-left 3px
.terminal-footer-status
  display flex
  align-items center
  gap 8px
  min-width 0
  white-space nowrap
.terminal-footer-status > span:not(.terminal-footer-dot)
  min-width 0
  overflow hidden
  text-overflow ellipsis
.terminal-footer-muted
  color var(--sp-text-muted)
.terminal-footer-dot
  width 8px
  height 8px
  border-radius 50%
  background var(--sp-text-disabled)
  &.online
    background var(--sp-success)
.batch-input-outer
  .bi-full
    display none
  &.bi-show
    line-height 20px
    .bi-full
      display inline
    .bi-compact
      display none
.batch-input-holder
  width 100px
@media (max-width: 500px)
  .batch-input-outer
    &.bi-show
      position fixed
      left 100px
      right 0
      bottom 0
      z-index 100
      background var(--main)
